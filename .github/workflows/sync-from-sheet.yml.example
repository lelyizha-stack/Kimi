name: Sync from Google Sheet
on:
  workflow_dispatch:
  schedule:
    - cron: "0 */6 * * *"
jobs:
  sync-sheet:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.x"
      - name: Sync CSV to JSON
        env:
          SHEET_CSV_URL: ${{ secrets.SHEET_CSV_URL }}
        run: |
          if [ -z "$SHEET_CSV_URL" ]; then
            echo "SHEET_CSV_URL secret belum diisi."
            exit 1
          fi
          python tools/sheets_to_json.py "$SHEET_CSV_URL"
      - name: Commit changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add data/games.json
          git diff --cached --quiet || git commit -m "Sync games.json from Google Sheet"
          git push
